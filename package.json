{
  "name": "traces",
  "version": "0.2.0",
  "private": true,
  "description": "Local-first knowledge workspace by Defendre Solutions — a 3D force-directed knowledge graph, markdown editor, and multi-provider AI assistant for exploring connections between your notes.",
  "license": "MIT",
  "author": {
    "name": "Defendre Solutions LLC",
    "email": "steve@defendresolutions.com",
    "url": "https://defendresolutions.com"
  },
  "homepage": "https://defendresolutions.com/products",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sdefendre/traces-app.git"
  },
  "main": "main/dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:next": "BUILD_STATIC=1 next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "verify:logic": "node scripts/verify-logic.mjs",
    "verify:editor": "tsc -p tsconfig.verify.json && node scripts/.verify-out/scripts/verify-editor-store.js",
    "verify:all": "bash scripts/run-verification.sh",
    "build": "pnpm build:next && pnpm build:electron",
    "dist": "pnpm build && electron-builder",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@lezer/highlight": "^1.2.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "ai": "^4.1.54",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force-3d": "^3.0.5",
    "lucide-react": "^0.575.0",
    "next": "^15.1.7",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.172.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.9",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/three": "^0.172.0",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.7.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.defendresolutions.traces",
    "productName": "Traces",
    "copyright": "Copyright © 2026 Defendre Solutions LLC",
    "directories": {
      "output": "release"
    },
    "files": [
      "main/dist/**/*",
      "src/**/*",
      ".next/**/*",
      "next.config.*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main/dist/main/index.js"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "darkModeSupport": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "Sdefendre",
      "repo": "traces-app",
      "releaseType": "release"
    }
  }
}
